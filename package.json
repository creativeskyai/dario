{
  "name": "@askalf/dario",
  "version": "3.6.1",
  "description": "A local LLM router. One endpoint, every provider — Claude subscriptions, OpenAI, OpenRouter, Groq, local LiteLLM, any OpenAI-compat endpoint — your tools don't need to change.",
  "type": "module",
  "bin": {
    "dario": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/cc-template-data.json dist/",
    "audit": "npm audit --production --audit-level=high",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "e2e": "node test/e2e.mjs",
    "compat": "node test/compat.mjs",
    "lint:pkg": "node scripts/check-package-json.mjs",
    "fix:pkg": "node -e \"const fs=require('fs');fs.writeFileSync('package.json',JSON.stringify(JSON.parse(fs.readFileSync('package.json','utf-8')),null,2)+'\\n')\""
  },
  "keywords": [
    "llm",
    "llm-router",
    "multi-provider",
    "openai-compat",
    "openai",
    "openrouter",
    "groq",
    "litellm",
    "ollama",
    "claude",
    "anthropic",
    "oauth",
    "proxy",
    "api",
    "subscription",
    "claude-max",
    "claude-pro",
    "ai",
    "cli",
    "developer-tools"
  ],
  "author": "askalf (https://github.com/askalf)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/askalf/dario.git"
  },
  "homepage": "https://github.com/askalf/dario",
  "bugs": {
    "url": "https://github.com/askalf/dario/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
